<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:IOTWaveDemo.ViewModels"
             xmlns:iot="using:IOTWave"
             xmlns:views="clr-namespace:IOTWave.Views;assembly=IOTWave"
             xmlns:models="clr-namespace:IOTWave.Models;assembly=IOTWave"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="IOTWaveDemo.Views.MainView"
             x:DataType="vm:MainViewModel">
  <Design.DataContext>
    <vm:MainViewModel />
  </Design.DataContext>

  <UserControl.Styles>
    <!-- WaveListPanel 公共样式（仅静态属性） -->
    <Style Selector="views|WaveListPanel.demoPanel">
      <Setter Property="ShowCursor" Value="True"/>
      <Setter Property="ShowTimeAxis" Value="True"/>
      <Setter Property="GridBrush" Value="#6400B4D8"/>
      <Setter Property="LabelBrush" Value="#7DD3FC"/>
      <Setter Property="IsInteractive" Value="True"/>
      <Setter Property="StatusPanelHeight" Value="20"/>
      <Setter Property="Background" Value="Black"/>
    </Style>

    <!-- 时间跳转按钮样式 -->
    <Style Selector="Button.jumpBtn">
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="Padding" Value="10,5"/>
      <Setter Property="CornerRadius" Value="4"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Template">
        <ControlTemplate>
          <ContentPresenter x:Name="PART_ContentPresenter"
                            Background="{TemplateBinding Background}"
                            Foreground="{TemplateBinding Foreground}"
                            Padding="{TemplateBinding Padding}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Content="{TemplateBinding Content}"/>
        </ControlTemplate>
      </Setter>
    </Style>
    <Style Selector="Button.jumpBtn:pointerover /template/ ContentPresenter">
      <Setter Property="TextBlock.Foreground" Value="Black"/>
      <Setter Property="Background" Value="White"/>
    </Style>
    <Style Selector="Button.jumpBtn:pressed /template/ ContentPresenter">
      <Setter Property="TextBlock.Foreground" Value="White"/>
      <Setter Property="Background" Value="#333333"/>
    </Style>
  </UserControl.Styles>

  <TabControl>

    <TabItem Header="IOTChart2示例">
      <views:IOTChart2 DataContext="{Binding BasicViewModel}" />
    </TabItem>

    <TabItem Header="滚动条示例2">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Text="此示例展示多个曲线面板，当面板数量较多时显示滚动条"
                   Margin="10"
                   FontSize="14"
                   Foreground="Gray"/>
        <views:IOTChart2 Grid.Row="1"
                         DataContext="{Binding ScrollableViewModel}"
                         AutoDistributePanelHeight="False"
                         VerticalScrollBarVisibility="Auto"/>
      </Grid>
    </TabItem>
 
    <TabItem Header="相对时间示例2">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Text="事件型曲线数据：启动时间9:05:43，每秒40点，共7秒。时间轴刻度对齐到基准时间(2s, 4s, 6s, 8s)，光标/标记显示相对时间"
                   Margin="10"
                   FontSize="14"
                   Foreground="Gray"
                   TextWrapping="Wrap"/>
        <views:IOTChart2 Grid.Row="1"
                      Classes="showValue"
                      DataContext="{Binding RelativeTimeViewModel}"/>
      </Grid>
    </TabItem>
    <TabItem Header="当前值显示示例">
      <views:WaveListPanel
          Classes="demoPanel"
          DataContext="{Binding CurrentValueViewModel}"
          ItemsSource="{Binding Items}"
          TimeMarkers="{Binding TimeMarkers}"
          TimeRangeMarkers="{Binding TimeRangeMarkers}"
          StartTime="{Binding BeginTime}"
          EndTime="{Binding EndTime}">
        <views:WaveListPanel.DataTemplates>
          <DataTemplate DataType="models:CurveGroup">
            <views:CurvePanel
                ChartGlobal="{Binding $parent[views:WaveListPanel]}"
                Foreground="#7DD3FC"
                Items="{Binding}"
                YMarkers="{Binding YMarkers}"
                Height="{Binding Height}">
              <views:CurvePanel.Template>
                <ControlTemplate>
                  <Grid Background="{TemplateBinding Background}">
                    <ListBox Name="PART_Legend"
                             Classes="legendBox curveLegendWithValue"
                             ItemsSource="{Binding Items.Curves, RelativeSource={RelativeSource TemplatedParent}}"/>
                  </Grid>
                </ControlTemplate>
              </views:CurvePanel.Template>
            </views:CurvePanel>
          </DataTemplate>
          <DataTemplate DataType="models:StatuSeriesGroup">
            <views:StatusPanel
                ChartGlobal="{Binding $parent[views:WaveListPanel]}"
                Items="{Binding}"
                Height="{Binding Height}"
                Margin="0,1" />
          </DataTemplate>
        </views:WaveListPanel.DataTemplates>
      </views:WaveListPanel>
    </TabItem>
      <TabItem Header="当前值显示示例2">
       <views:IOTChart2 Classes="showValue" DataContext="{Binding CurrentValueViewModel}" />
     
    </TabItem>
     <TabItem Header="日报表显示示例">
      <views:WaveListPanel
          Classes="demoPanel"
          DataContext="{Binding DayReportViewModel}"
          ItemsSource="{Binding Items}"
          TimeMarkers="{Binding TimeMarkers}"
          TimeRangeMarkers="{Binding TimeRangeMarkers}"
          StartTime="{Binding BeginTime}"
          EndTime="{Binding EndTime}">
        <views:WaveListPanel.DataTemplates>
          <DataTemplate DataType="models:CurveGroup">
            <views:CurvePanel
                ChartGlobal="{Binding $parent[views:WaveListPanel]}"
                Foreground="#7DD3FC"
                Items="{Binding}"
                YMarkers="{Binding YMarkers}"
                Height="{Binding Height}">
              <views:CurvePanel.Template>
                <ControlTemplate>
                  <Grid Background="{TemplateBinding Background}">
                    <ListBox Name="PART_Legend"
                             Classes="legendBox reportLegend"
                             ItemsSource="{Binding Items.Curves, RelativeSource={RelativeSource TemplatedParent}}"/>
                  </Grid>
                </ControlTemplate>
              </views:CurvePanel.Template>
            </views:CurvePanel>
          </DataTemplate>
          <DataTemplate DataType="models:StatuSeriesGroup">
            <views:StatusPanel
                ChartGlobal="{Binding $parent[views:WaveListPanel]}"
                Items="{Binding}"
                Height="{Binding Height}"
                Margin="0,1" />
          </DataTemplate>
        </views:WaveListPanel.DataTemplates>
      </views:WaveListPanel>
    </TabItem>

    <!-- 时间跳转演示 -->
    <TabItem Header="时间跳转演示">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 跳转按钮面板 -->
        <Border Background="#1A1A1A" Padding="10">
          <StackPanel Orientation="Horizontal" Spacing="10">
            <TextBlock Text="时间跳转：" VerticalAlignment="Center" Foreground="White" Margin="0,0,10,0"/>

            <Button Content="跳转到起始" Classes="jumpBtn"
                    Command="{Binding TimeJumpDemoViewModel.JumpToStartCommand}"
                    Background="#3B82F6"/>

            <Button Content="跳转到中间" Classes="jumpBtn"
                    Command="{Binding TimeJumpDemoViewModel.JumpToMiddleCommand}"
                    Background="#8B5CF6"/>

            <Button Content="跳转到结束" Classes="jumpBtn"
                    Command="{Binding TimeJumpDemoViewModel.JumpToEndCommand}"
                    Background="#EC4899"/>

            <Separator Width="20" Background="Transparent"/>

            <TextBlock Text="指定时间：" VerticalAlignment="Center" Foreground="White" Margin="10,0,5,0"/>

            <Button Content="跳转到6:30" Classes="jumpBtn"
                    Command="{Binding TimeJumpDemoViewModel.JumpToTargetTime630Command}"
                    Background="#10B981"/>

            <Button Content="跳转到17:25" Classes="jumpBtn"
                    Command="{Binding TimeJumpDemoViewModel.JumpToTargetTime1725Command}"
                    Background="#F59E0B"/>

            <Separator Width="20" Background="Transparent"/>

            <TextBlock Text="播放：" VerticalAlignment="Center" Foreground="White" Margin="0,0,5,0"/>

            <Button Classes="jumpBtn"
                    Command="{Binding TimeJumpDemoViewModel.PlayCommand}"
                    Background="#22C55E">
              <Panel>
                <TextBlock Text="▶" FontSize="12" IsVisible="{Binding !TimeJumpDemoViewModel.IsPlaying}"/>
                <TextBlock Text="⏸" FontSize="12" IsVisible="{Binding TimeJumpDemoViewModel.IsPlaying}"/>
              </Panel>
            </Button>

            <TextBlock Text="速度：" VerticalAlignment="Center" Foreground="White" Margin="10,0,5,0"/>
            <ComboBox Width="80"
                      SelectedIndex="{Binding TimeJumpDemoViewModel.PlaySpeedIndex}">
              <ComboBoxItem Content="0.5x"/>
              <ComboBoxItem Content="1x"/>
              <ComboBoxItem Content="2x"/>
              <ComboBoxItem Content="4x"/>
              <ComboBoxItem Content="8x"/>
            </ComboBox>
          </StackPanel>
        </Border>

        <views:IOTChart2 x:Name="TimeJumpChart"
                        Grid.Row="1"
                        DataContext="{Binding TimeJumpDemoViewModel.DataViewModel}"
                        AutoDistributePanelHeight="True"/>
      </Grid>
    </TabItem>
  </TabControl>
</UserControl>
