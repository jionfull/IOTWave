<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:IOTWaveDemo.ViewModels"
             xmlns:iot="using:IOTWave"
             xmlns:models="clr-namespace:IotWave.Models;assembly=IOTWave"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="IOTWaveDemo.Views.MainView"
             x:DataType="vm:MainViewModel">
  <Design.DataContext>
    <vm:MainViewModel />
  </Design.DataContext>

  <TabControl>
    <TabItem Header="基本示例">
      <iot:IOTChart DataContext="{Binding BasicViewModel}" />
    </TabItem>
    <TabItem Header="滚动条示例">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Text="此示例展示多个曲线面板，当面板数量较多时显示滚动条"
                   Margin="10"
                   FontSize="14"
                   Foreground="Gray"/>
        <iot:IOTChart Grid.Row="1"
                      DataContext="{Binding ScrollableViewModel}"
                      AutoDistributePanelHeight="False"
                      VerticalScrollBarVisibility="Auto"/>
      </Grid>
    </TabItem>
    <TabItem Header="相对时间示例">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Text="事件型曲线数据：启动时间9:05:43，每秒40点，共7秒。时间轴刻度对齐到基准时间(2s, 4s, 6s, 8s)，光标/标记显示相对时间"
                   Margin="10"
                   FontSize="14"
                   Foreground="Gray"
                   TextWrapping="Wrap"/>
        <iot:IOTChart Grid.Row="1"
                      DataContext="{Binding RelativeTimeViewModel}"/>
      </Grid>
    </TabItem>
    <TabItem Header="当前值显示示例">
      <TabItem.Resources>
        <!-- 自定义图例模板：横向紧凑布局 -->
        <DataTemplate x:Key="CurveLegendWithValueTemplate" DataType="models:CurveData">
          <StackPanel Orientation="Horizontal" Spacing="4" Margin="5,0">
            <CheckBox Background="Transparent"
                      IsChecked="{Binding IsVisible}"
                      Content="{Binding Name}"
                      Foreground="{Binding Brush}">
              <CheckBox.Styles>
                <Style Selector="CheckBox:pointerover">
                  <Setter Property="Foreground" Value="{Binding Brush}"/>
                </Style>
                <Style Selector="CheckBox /template/ Border#NormalRectangle">
                  <Setter Property="Background" Value="Transparent"/>
                  <Setter Property="BorderThickness" Value="2"/>
                  <Setter Property="BorderBrush" Value="{Binding Brush}"/>
                </Style>
              </CheckBox.Styles>
            </CheckBox>
            <TextBlock Text="[" Foreground="{Binding Brush}" Opacity="0.6" FontSize="10" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding CurrentTimeText}" Foreground="{Binding Brush}" Opacity="0.8" FontSize="10" VerticalAlignment="Center"/>
            <TextBlock Text="]" Foreground="{Binding Brush}" Opacity="0.6" FontSize="10" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding CurrentValueText}" Foreground="{Binding Brush}" FontWeight="Bold" FontSize="11" VerticalAlignment="Center"/>
          </StackPanel>
        </DataTemplate>
      </TabItem.Resources>
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Text="图例中显示光标位置的数据值：移动鼠标或点击图表，图例下方会实时显示光标时间点前最近的数据时间和数值"
                   Margin="10"
                   FontSize="14"
                   Foreground="Gray"
                   TextWrapping="Wrap"/>
        <iot:IOTChart Grid.Row="1"
                      DataContext="{Binding CurrentValueViewModel}"
                      ShowCurrentValue="True"/>
      </Grid>
    </TabItem>
  </TabControl>
</UserControl>
