<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:IOTWaveDemo.ViewModels"
             xmlns:iot="using:IOTWave"
             xmlns:views="clr-namespace:IOTWave.Views;assembly=IOTWave"
             xmlns:models="clr-namespace:IOTWave.Models;assembly=IOTWave"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="IOTWaveDemo.Views.MainView"
             x:DataType="vm:MainViewModel">
  <Design.DataContext>
    <vm:MainViewModel />
  </Design.DataContext>

  <TabControl>
 
 
 
     <TabItem Header="日报表显示示例">
      <!-- 通过自定义 DataTemplate 给 CurvePanel2 设置 Classes -->
      <views:WaveListPanel
          DataContext="{Binding DayReportViewModel}"
          StartTime="{Binding BeginTime}"
          EndTime="{Binding EndTime}"
          ShowCursor="True"
          ItemsSource="{Binding Items}"
          ShowTimeAxis="True"
          GridBrush="#6400B4D8"
          LabelBrush="#7DD3FC"
          IsInteractive="True"
          StatusPanelHeight="20"
          TimeMarkers="{Binding TimeMarkers}"
          TimeRangeMarkers="{Binding TimeRangeMarkers}"
          ShowCurrentValue="True"
          Background="Black">
        <views:WaveListPanel.DataTemplates>
          <DataTemplate DataType="models:CurveGroup">
            <views:CurvePanel2
                ChartGlobal="{Binding $parent[views:WaveListPanel]}"
                Foreground="#7DD3FC"
                Items="{Binding}"
                YMarkers="{Binding YMarkers}"
                Height="{Binding Height}">
              <!-- 直接定义模板：显示当前值 -->
              <views:CurvePanel2.Template>
                <ControlTemplate>
                  <Grid Background="{TemplateBinding Background}">
                    <ListBox Name="PART_Legend"
                             Background="Transparent"
                             BorderBrush="Transparent"
                             BorderThickness="0"
                             ItemsSource="{Binding Items.Curves, RelativeSource={RelativeSource TemplatedParent}}">
                      <ListBox.Template>
                        <ControlTemplate>
                          <Border Name="border"
                                  ClipToBounds="{TemplateBinding ClipToBounds}"
                                  Background="Transparent"
                                  BorderBrush="Transparent"
                                  BorderThickness="0">
                            <ScrollViewer Name="PART_ScrollViewer"
                                          VerticalSnapPointsType="{TemplateBinding (ScrollViewer.VerticalSnapPointsType)}"
                                          HorizontalSnapPointsType="{TemplateBinding (ScrollViewer.HorizontalSnapPointsType)}"
                                          HorizontalScrollBarVisibility="Disabled"
                                          VerticalScrollBarVisibility="Auto"
                                          IsScrollChainingEnabled="{TemplateBinding (ScrollViewer.IsScrollChainingEnabled)}"
                                          IsScrollInertiaEnabled="{TemplateBinding (ScrollViewer.IsScrollInertiaEnabled)}"
                                          IsDeferredScrollingEnabled="{TemplateBinding (ScrollViewer.IsDeferredScrollingEnabled)}"
                                          AllowAutoHide="{TemplateBinding (ScrollViewer.AllowAutoHide)}"
                                          BringIntoViewOnFocusChange="{TemplateBinding (ScrollViewer.BringIntoViewOnFocusChange)}">
                              <ItemsPresenter Name="PART_ItemsPresenter"
                                              ItemsPanel="{TemplateBinding ItemsPanel}"
                                              Margin="{TemplateBinding Padding}"/>
                            </ScrollViewer>
                          </Border>
                        </ControlTemplate>
                      </ListBox.Template>
                      <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                          <StackPanel Orientation="Horizontal" Background="Transparent"/>
                        </ItemsPanelTemplate>
                      </ListBox.ItemsPanel>
                      <ListBox.ItemTemplate>
                        <DataTemplate DataType="models:CurveData">
                          <StackPanel Margin="5,0" Spacing="2" Background="Transparent">
                            <!-- 曲线名称和可见性控制 -->
                            <CheckBox Background="Transparent"
                                      IsChecked="{Binding IsVisible}"
                                      Content="{Binding Name}"
                                      Foreground="{Binding Brush}">
                              <CheckBox.Styles>
                                <Style Selector="CheckBox:pointerover">
                                  <Setter Property="Foreground" Value="{Binding Brush}"/>
                                </Style>
                                <Style Selector="CheckBox:unchecked /template/ Border#NormalRectangle">
                                  <Setter Property="Background" Value="Transparent"/>
                                  <Setter Property="BorderThickness" Value="2"/>
                                  <Setter Property="BorderBrush" Value="{Binding Brush}"/>
                                </Style>
                                <Style Selector="CheckBox:checked /template/ Border#NormalRectangle">
                                  <Setter Property="Background" Value="Transparent"/>
                                  <Setter Property="BorderThickness" Value="2"/>
                                  <Setter Property="BorderBrush" Value="{Binding Brush}"/>
                                </Style>
                              </CheckBox.Styles>
                            </CheckBox>
                            <!-- 当前值显示区域 -->
                            <ContentControl
                              Background="Transparent"
                             
                              Content="{Binding CursorPoint}">

                              <ContentControl.ContentTemplate>
                                <DataTemplate DataType="models:ReportPoint">
                                  <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding ReportTime}"
                                               FontSize="10"
                                               Foreground="Aqua"
                                               Opacity="0.8"/>

                                    <TextBlock Text="{Binding Value}"
                                               FontSize="10"
                                               Foreground="Aqua"
                                               FontWeight="Bold"/>
                                  </StackPanel>
                                </DataTemplate>
                              </ContentControl.ContentTemplate>
                            </ContentControl>
                          </StackPanel>
                        </DataTemplate>
                      </ListBox.ItemTemplate>
                    </ListBox>
                  </Grid>
                </ControlTemplate>
              </views:CurvePanel2.Template>
            </views:CurvePanel2>
          </DataTemplate>
          <DataTemplate DataType="models:StatuSeriesGroup">
            <views:StatusPanel
                ChartGlobal="{Binding $parent[views:WaveListPanel]}"
                Items="{Binding}"
                Height="{Binding Height}"
                Margin="0,1" />
          </DataTemplate>
        </views:WaveListPanel.DataTemplates>
      </views:WaveListPanel>
    </TabItem>
  </TabControl>
</UserControl>
