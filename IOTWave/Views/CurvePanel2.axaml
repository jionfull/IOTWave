<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:IOTWave.Views">

  <Design.PreviewWith>
    <StackPanel Width="400" Spacing="10">
      <StackPanel Background="{DynamicResource SystemRegionBrush}">
        <controls:CurvePanel2 />
        <controls:CurvePanel2 Classes="curveLegendWithValue" />
      </StackPanel>
    </StackPanel>
  </Design.PreviewWith>

  <!-- 默认样式：仅显示图例名称 -->
  <Style Selector="controls|CurvePanel2">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="Template">
      <ControlTemplate>
        <Grid Background="{TemplateBinding Background}">
          <ListBox Name="PART_Legend"
                   Classes="curveLegend"
                   ItemsSource="{Binding Items.Curves, RelativeSource={RelativeSource TemplatedParent}}"/>
        </Grid>
      </ControlTemplate>
    </Setter>
  </Style>

</Styles>
