<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="using:IOTWave.Models">
    
    <!-- 曲线图例 ListBox 的 DataTemplate -->
    <Design.PreviewWith>
        <ListBox ItemsSource="{Binding Curves}">
            <ListBox.ItemTemplate>
                <StaticResource ResourceKey="CurveLegendItemTemplate"/>
            </ListBox.ItemTemplate>
        </ListBox>
    </Design.PreviewWith>

    <!-- 曲线图例项模板 - 可被外部覆盖 -->
    <Styles.Resources>
        <!-- 基础模板：仅显示曲线名称 -->
        <DataTemplate x:Key="CurveLegendItemTemplate" DataType="models:CurveData">
            <CheckBox Background="Transparent" 
                      IsChecked="{Binding IsVisible}" 
                      Content="{Binding Name}"
                      Foreground="{Binding Brush}"
                      Margin="5,0">
                <CheckBox.Styles>
                    <Style Selector="CheckBox:pointerover">
                        <Setter Property="Foreground" Value="{Binding Brush}"/>
                    </Style>
                    <Style Selector="CheckBox:unchecked /template/ Border#NormalRectangle">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="2"/>
                        <Setter Property="BorderBrush" Value="{Binding Brush}"/>
                    </Style>
                    <Style Selector="CheckBox:checked /template/ Border#NormalRectangle">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="2"/>
                        <Setter Property="BorderBrush" Value="{Binding Brush}"/>
                    </Style>
                </CheckBox.Styles>
            </CheckBox>
        </DataTemplate>

        <!-- 带数值显示的模板：显示曲线名称 + 当前时间 + 当前值 -->
        <DataTemplate x:Key="CurveLegendWithValueTemplate" DataType="models:CurveData">
            <StackPanel Orientation="Vertical" Margin="5,0" Spacing="2">
                <!-- 曲线名称和可见性控制 -->
                <CheckBox Background="Transparent" 
                          IsChecked="{Binding IsVisible}" 
                          Content="{Binding Name}"
                          Foreground="{Binding Brush}">
                    <CheckBox.Styles>
                        <Style Selector="CheckBox:pointerover">
                            <Setter Property="Foreground" Value="{Binding Brush}"/>
                        </Style>
                        <Style Selector="CheckBox:unchecked /template/ Border#NormalRectangle">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="2"/>
                            <Setter Property="BorderBrush" Value="{Binding Brush}"/>
                        </Style>
                        <Style Selector="CheckBox:checked /template/ Border#NormalRectangle">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="2"/>
                            <Setter Property="BorderBrush" Value="{Binding Brush}"/>
                        </Style>
                    </CheckBox.Styles>
                </CheckBox>
                
                <!-- 当前值显示区域 -->
                <StackPanel Orientation="Horizontal" Spacing="4" Margin="20,0,0,0">
                    <TextBlock Text="{Binding CurrentTimeText}" 
                               FontSize="10" 
                               Foreground="{Binding Brush}"
                               Opacity="0.8"/>
                    <TextBlock Text=":" 
                               FontSize="10" 
                               Foreground="{Binding Brush}"
                               Opacity="0.6"/>
                    <TextBlock Text="{Binding CurrentValueText}" 
                               FontSize="10" 
                               Foreground="{Binding Brush}"
                               FontWeight="Bold"/>
                </StackPanel>
            </StackPanel>
        </DataTemplate>

        <!-- 日报表图例项模板 -->
        <DataTemplate x:Key="ReportLegendItemTemplate" DataType="models:CurveData">
            <StackPanel Margin="5,0" Spacing="2" Background="Transparent">
                <!-- 曲线名称和可见性控制 -->
                <CheckBox Background="Transparent"
                          IsChecked="{Binding IsVisible}"
                          Content="{Binding Name}"
                          Foreground="{Binding Brush}">
                    <CheckBox.Styles>
                        <Style Selector="CheckBox:pointerover">
                            <Setter Property="Foreground" Value="{Binding Brush}"/>
                        </Style>
                        <Style Selector="CheckBox:unchecked /template/ Border#NormalRectangle">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="2"/>
                            <Setter Property="BorderBrush" Value="{Binding Brush}"/>
                        </Style>
                        <Style Selector="CheckBox:checked /template/ Border#NormalRectangle">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="2"/>
                            <Setter Property="BorderBrush" Value="{Binding Brush}"/>
                        </Style>
                    </CheckBox.Styles>
                </CheckBox>
                <!-- 当前值显示区域 -->
                <ContentControl
                  Background="Transparent"
                  Tag="{Binding Brush}"
                  Content="{Binding CursorPoint}">
                    <ContentControl.ContentTemplate>
                        <DataTemplate DataType="models:ReportPoint">
                            <StackPanel Orientation="Vertical">
                                <TextBlock Text="{Binding ReportTime,StringFormat='{}{0:HH:mm:ss}'} "
                                           FontSize="10"
                                           Foreground="{Binding $parent[ContentControl].Tag}"
                                           Opacity="0.8"/>
                                <TextBlock Text="{Binding Value,StringFormat='{}{0:F2}'}"
                                           FontSize="10"
                                           Foreground="{Binding $parent[ContentControl].Tag}"
                                           FontWeight="Bold"/>
                            </StackPanel>
                        </DataTemplate>
                    </ContentControl.ContentTemplate>
                </ContentControl>
            </StackPanel>
        </DataTemplate>
    </Styles.Resources>

    <!-- 图例 ListBox 公共基础样式 -->
    <Style Selector="ListBox.legendBox">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="VerticalAlignment" Value="Top"/>
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" Background="Transparent"/>
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate>
                    <Border Name="border"
                            ClipToBounds="{TemplateBinding ClipToBounds}"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="0">
                        <ScrollViewer Name="PART_ScrollViewer"
                                      VerticalSnapPointsType="{TemplateBinding (ScrollViewer.VerticalSnapPointsType)}"
                                      HorizontalSnapPointsType="{TemplateBinding (ScrollViewer.HorizontalSnapPointsType)}"
                                      HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollBarVisibility="Auto"
                                      IsScrollChainingEnabled="{TemplateBinding (ScrollViewer.IsScrollChainingEnabled)}"
                                      IsScrollInertiaEnabled="{TemplateBinding (ScrollViewer.IsScrollInertiaEnabled)}"
                                      IsDeferredScrollingEnabled="{TemplateBinding (ScrollViewer.IsDeferredScrollingEnabled)}"
                                      AllowAutoHide="{TemplateBinding (ScrollViewer.AllowAutoHide)}"
                                      BringIntoViewOnFocusChange="{TemplateBinding (ScrollViewer.BringIntoViewOnFocusChange)}">
                            <ItemsPresenter Name="PART_ItemsPresenter"
                                            ItemsPanel="{TemplateBinding ItemsPanel}"
                                            Margin="{TemplateBinding Padding}"/>
                        </ScrollViewer>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 图例 ListBoxItem 公共样式 -->
    <Style Selector="ListBox.legendBox > ListBoxItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
    </Style>

    <Style Selector="ListBox.legendBox > ListBoxItem:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <Style Selector="ListBox.legendBox > ListBoxItem:selected /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <!-- 日报表 ListBox 样式 -->
    <Style Selector="ListBox.reportLegend">
        <Setter Property="ItemTemplate" Value="{StaticResource ReportLegendItemTemplate}"/>
    </Style>

    <!-- ListBox 容器样式 - 基础样式 -->
    <Style Selector="ListBox.curveLegend">
        <Setter Property="Height" Value="40"/>
        <Setter Property="ItemTemplate" Value="{StaticResource CurveLegendItemTemplate}"/>
    </Style>

    <!-- ListBox 容器样式 - 带数值显示 -->
    <Style Selector="ListBox.curveLegendWithValue">
        <Setter Property="Height" Value="55"/>
        <Setter Property="ItemTemplate" Value="{StaticResource CurveLegendWithValueTemplate}"/>
    </Style>

</Styles>
